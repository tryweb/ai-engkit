# OpenChamber Environment Variables
# Copy this file to .env and customize values

# === OpenCode Settings ===
# OpenCode server password (required for API access)
OPENCODE_SERVER_PASSWORD=devonly

# OpenCode plugins to load (comma-separated).
# Set here in .env (not via shell export) to avoid host environment leaking into containers.
OPENCODE_PLUGINS=oh-my-openagent,superpowers@git+https://github.com/obra/superpowers.git

# === UI Settings ===
# Web UI password (required for browser authentication)
OPENCHAMBER_UI_PASSWORD=chamber

# === Ports ===
# Host port for OpenChamber Web UI
CHAMBER_PORT=8000

# === Workspace ===
# Workspace volume type (v0.5.0+ uses named volumes by default):
# - Leave commented/unset: Uses Docker named volume (recommended, fully managed)
# - Set to host path: Uses bind mount (e.g., ./workspace, /home/user/projects)
#   Useful for direct file editing with local IDE
# WORKSPACE_PATH=./workspace
